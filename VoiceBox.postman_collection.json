    {
      "name": "Public",
      "item": [
        {
          "name": "Submit Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"This title has twenty chars\",\n  \"tags\": [\"Harassment\"],\n  \"identity\": \"Optional identity details\",\n  \"comment\": \"At least 150 characters describing what happened, where it happened, who was involved, and any additional context that can help administrators review and respond quickly.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/reports",
              "host": ["{{baseUrl}}"],
              "path": ["reports"]
            }
          },
          "response": []
        },
        {
          "name": "List Reports (Public Feed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/reports?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["reports"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin001\",\n  \"password\": \"strongPass123\",\n  \"membershipCode\": \"A1B2C3D4E5\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin001\",\n  \"password\": \"strongPass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "On success, saves token to collection variable token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin (Protected)",
      "item": [
        {
          "name": "Filter/Search Reports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/reports?status=Unhandled&tags=Harassment,Assault&search=class&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reports"],
              "query": [
                {
                  "key": "status",
                  "value": "Unhandled"
                },
                {
                  "key": "tags",
                  "value": "Harassment,Assault"
                },
                {
                  "key": "search",
                  "value": "class"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Report",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Queue\",\n  \"adminNote\": \"Escalated to welfare office for immediate follow-up.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/reports/{{reportId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reports", "{{reportId}}"]
            }
          },
          "response": []
        },
        {
